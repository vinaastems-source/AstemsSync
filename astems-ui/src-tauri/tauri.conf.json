{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AstemsSync",
  "version": "1.0.0",
  "identifier": "com.vinaastems.astems-sync",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AstemsSync - POS 업데이터",
        "width": 480,
        "height": 700,
        "minWidth": 420,
        "minHeight": 620,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
